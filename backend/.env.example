PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
DYNAMODB_USERS_TABLE=enm-users
DYNAMODB_SALES_TABLE=enm-sales
# Optional: point to DynamoDB Local in dev
# DYNAMODB_ENDPOINT=http://localhost:8000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set COGNITO_DISABLED=true for local dev (uses bcrypt + local JWT instead)
COGNITO_DISABLED=true
JWT_SECRET=change_me_to_a_32_char_random_secret

# Production Cognito settings (leave blank in dev)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── S3 Image Uploads ─────────────────────────────────────────────────────────
S3_BUCKET_NAME=enm-uploads-123456789012-production
# EC2 uses IAM instance role in production — no keys needed
# For local dev, use AWS CLI credentials or set:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ─── Frontend ─────────────────────────────────────────────────────────────────
# REACT_APP_GOOGLE_MAPS_API_KEY is set in frontend/.env
